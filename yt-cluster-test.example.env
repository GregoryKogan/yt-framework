# Copy to yt-cluster-test.env (gitignored) for real-cluster pytest integration tests.
# See docs/testing/yt-cluster-integration.md and CONTRIBUTING.md (Testing).

YT_PROXY=https://your-yt-proxy.example
YT_TOKEN=replace-me

# Optional scheduler knobs (defaults: pool default, 1 GiB RAM, 1 CPU, 1 job)
# YT_TEST_POOL=default
# YT_TEST_POOL_TREE=
# YT_TEST_MEMORY_GB=1
# YT_TEST_CPU_LIMIT=1
# YT_TEST_JOB_COUNT=1
